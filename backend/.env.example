# Ollama connection
OLLAMA_HOST=http://localhost:11434

# Models (match what you pulled via `ollama pull`)
MODEL_LIVE=qwen2.5:3b-instruct-q4_K_M
MODEL_BG=qwen2.5:7b-instruct-q4_K_M
MODEL_MATH=qwen2.5-math:7b-instruct-q4_K_M
MODEL_EMBED=mxbai-embed-large

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/ibps.db

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Server
HOST=0.0.0.0
PORT=8001
